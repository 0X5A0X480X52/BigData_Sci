# OpenAI-compatible API 配置；仅 --llm 或 --embed_backend openai 时需要。
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_API_KEY=你的APIKey
OPENAI_CHAT_MODEL=glm-4.7-flash
OPENAI_EMBED_MODEL=embedding-3
OPENAI_USE_JSON_MODE=1
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=3

# 本地 sentence-transformers embedding；--embed_backend local 时使用。
LOCAL_EMBED_MODEL=BAAI/bge-base-zh-v1.5
LOCAL_EMBED_DEVICE=auto
LOCAL_EMBED_CACHE_DIR=
# Windows 下如不想看到 HF symlink warning，可设置：
# HF_HUB_DISABLE_SYMLINKS_WARNING=1
